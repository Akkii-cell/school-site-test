<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>港区白金の丘中学校 第7学年 共有サイト</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f5f5f7;
      --surface: rgba(255, 255, 255, 0.92);
      --border: rgba(15, 23, 42, 0.08);
      --text: #111827;
      --muted: #6b7280;
      --accent: #0071e3;
      --shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
      --radius-xl: 28px;
      --radius-lg: 22px;
      --max-width: 1220px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: "SF Pro Display", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Yu Gothic UI", sans-serif;
      color: var(--text);
      background: radial-gradient(circle at top left, rgba(0, 113, 227, 0.08), transparent 32%), radial-gradient(circle at top right, rgba(15, 169, 107, 0.08), transparent 28%), var(--bg);
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    button, input, select, textarea { font: inherit; }
    img { max-width: 100%; display: block; }
    button { border: none; cursor: pointer; }

    .shell {
      width: min(var(--max-width), calc(100vw - 32px));
      margin: 0 auto;
      padding: 28px 0 calc(80px + env(safe-area-inset-bottom));
    }

    .card, .frosted, .panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
      backdrop-filter: blur(24px);
    }

    .hero-card {
      padding: 32px;
      overflow: hidden;
      position: relative;
    }

    .hero-card::after {
      content: "";
      position: absolute;
      inset: auto -100px -120px auto;
      width: 280px;
      height: 280px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(0, 113, 227, 0.16), transparent 62%);
      pointer-events: none;
    }

    h1, h2, h3, h4, p { margin: 0; }

    .hero-title {
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 1.08;
      letter-spacing: -0.04em;
      margin-bottom: 14px;
    }

    .hero-lead {
      max-width: 60ch;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.7;
    }

    .toolbar {
      display: grid;
      gap: 16px;
      padding: 22px;
      margin-bottom: 18px;
    }

    .toolbar-row {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      align-items: center;
    }

    .chip {
      min-height: 46px;
      padding: 0 15px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.05);
      color: #334155;
      font-weight: 700;
    }

    .chip.active {
      background: rgba(0, 113, 227, 0.12);
      color: var(--accent);
    }

    .date-nav {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .date-display {
      font-size: 1.1rem;
      font-weight: 700;
      min-width: 220px;
    }

    .panel {
      padding: 24px;
    }

    .panel-title {
      font-size: 1.2rem;
      letter-spacing: -0.03em;
      margin-bottom: 16px;
    }

    .post-card {
      border: 1px solid rgba(148, 163, 184, 0.16);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.92));
      border-radius: var(--radius-lg);
      padding: 22px;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
      margin-bottom: 16px;
    }

    .post-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 12px;
    }

    .post-title {
      font-size: 1.3rem;
      line-height: 1.25;
      letter-spacing: -0.03em;
      flex: 1;
    }

    .post-body {
      color: #344054;
      line-height: 1.8;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      margin-bottom: 16px;
    }

    .post-meta {
      font-size: 0.85rem;
      color: var(--muted);
      margin-bottom: 16px;
    }

    .badge {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 700;
      margin-right: 8px;
      margin-bottom: 8px;
    }

    .badge.schedule { background: rgba(0, 113, 227, 0.1); color: #0071e3; }
    .badge.homework { background: rgba(15, 159, 110, 0.12); color: #0f9f6e; }
    .badge.notice { background: rgba(217, 119, 6, 0.12); color: #d97706; }

    .comment-item {
      background: rgba(248, 250, 252, 0.9);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px 16px;
      margin-bottom: 12px;
    }

    .comment-author {
      font-weight: 700;
      font-size: 0.95rem;
      margin-bottom: 4px;
    }

    .comment-text {
      color: #374151;
      line-height: 1.6;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }

    .empty-state {
      padding: 28px 22px;
      border-radius: 20px;
      background: rgba(248, 250, 252, 0.9);
      border: 1px dashed var(--border);
      color: var(--muted);
      line-height: 1.8;
      text-align: center;
    }

    .button, .ghost-button, .danger-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 48px;
      padding: 0 16px;
      border-radius: 999px;
      font-weight: 700;
      transition: transform 0.18s ease;
    }

    .button {
      background: linear-gradient(135deg, #0071e3, #2e90fa);
      color: #fff;
      box-shadow: 0 16px 32px rgba(0, 113, 227, 0.22);
    }

    .ghost-button {
      background: rgba(255, 255, 255, 0.88);
      color: #1f2937;
      border: 1px solid var(--border);
    }

    .danger-button {
      background: rgba(217, 45, 32, 0.12);
      color: #d92d20;
    }

    .modal {
      position: fixed;
      inset: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 22px;
      background: rgba(15, 23, 42, 0.44);
      backdrop-filter: blur(16px);
      z-index: 100;
      opacity: 1;
      pointer-events: auto;
    }

    .modal.hidden {
      opacity: 0;
      pointer-events: none;
      display: none;
    }

    .modal-panel {
      width: min(720px, 100%);
      max-height: 90vh;
      overflow: auto;
      padding: 28px;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.98);
      border: 1px solid var(--border);
      box-shadow: 0 30px 70px rgba(15, 23, 42, 0.22);
    }

    .modal-title {
      font-size: 1.55rem;
      letter-spacing: -0.04em;
      margin-bottom: 16px;
    }

    .modal-actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 24px;
      transform: translateX(-50%) translateY(18px);
      padding: 14px 18px;
      border-radius: 999px;
      background: rgba(17, 24, 39, 0.92);
      color: #fff;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.22s ease;
      z-index: 120;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .mobile-menu-button {
      display: none;
      position: fixed;
      top: 16px;
      right: 16px;
      background: var(--accent);
      color: #fff;
      width: 44px;
      height: 44px;
      border-radius: 12px;
      font-size: 24px;
      z-index: 500;
    }

    .mobile-menu-panel {
      display: none;
      position: fixed;
      top: 70px;
      right: 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow);
      z-index: 450;
      padding: 12px;
      gap: 8px;
      flex-direction: column;
      min-width: 160px;
    }

    .mobile-menu-panel.active {
      display: flex;
    }

    .mobile-menu-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.3);
      z-index: 400;
    }

    .mobile-menu-overlay.active {
      display: block;
    }

    .mobile-menu-item {
      padding: 12px 16px;
      border-radius: 12px;
      background: rgba(0, 113, 227, 0.1);
      color: var(--accent);
      font-weight: 600;
      font-size: 0.95rem;
    }

    .admin-footer {
      position: fixed;
      bottom: 16px;
      right: 16px;
      z-index: 100;
    }

    .admin-button-small {
      min-height: 40px;
      padding: 0 12px;
      font-size: 0.85rem;
    }

    .pending-screen {
      width: 100%;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .pending-panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      padding: 40px;
      max-width: 600px;
      text-align: center;
      box-shadow: var(--shadow);
    }

    .pending-title {
      font-size: 2rem;
      letter-spacing: -0.04em;
      margin-bottom: 16px;
    }

    .pending-text {
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.8;
      margin-bottom: 24px;
    }

    @media (max-width: 768px) {
      .shell {
        width: min(calc(100vw - 18px), var(--max-width));
        padding-top: 14px;
      }

      .mobile-menu-button {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .chip-row {
        display: none;
      }
    }
  </style>
</head>
<body>
  <!-- ログイン画面 -->
  <div class="modal" id="loginModal">
    <div class="modal-panel" style="width: min(520px, 100%);">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2 class="modal-title">ログイン</h2>
        <div style="display: flex; gap: 8px;">
          <button type="button" id="userTabButton" class="ghost-button" style="min-height: 36px; padding: 0 12px; font-size: 0.85rem; font-weight: 700;">ユーザー</button>
          <button type="button" id="adminTabButton" class="ghost-button" style="min-height: 36px; padding: 0 12px; font-size: 0.75rem;">管理者</button>
        </div>
      </div>

      <!-- ユーザーログイン -->
      <div id="userLoginTab">
        <p style="color: var(--muted); margin-bottom: 24px;">Google または メールアドレスでログインしてください。</p>
        
        <div style="display: grid; gap: 12px;">
          <button class="button" id="googleLoginButton" type="button" style="width: 100%;">
            Google でログイン
          </button>
          
          <div style="display: flex; align-items: center; gap: 12px; margin: 20px 0;">
            <div style="flex: 1; height: 1px; background: var(--border);"></div>
            <span style="color: var(--muted); font-size: 0.9rem;">または</span>
            <div style="flex: 1; height: 1px; background: var(--border);"></div>
          </div>

          <form id="emailLoginForm" style="display: grid; gap: 12px;">
            <input id="emailInput" type="email" placeholder="メールアドレス" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;">
            <input id="passwordInput" type="password" placeholder="パスワード" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;">
            <button type="submit" class="button" style="width: 100%;">メールでログイン</button>
          </form>

          <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border);">
          </div>
        </div>
      </div>

      <!-- 管理者ログイン -->
      <div id="adminLoginTab" style="display: none;">
        <p style="color: var(--muted); margin-bottom: 24px; font-size: 0.9rem;">管理者用ログインページ</p>
        
        <form id="adminLoginForm" style="display: grid; gap: 12px;">
          <input id="adminEmailInput" type="email" placeholder="メールアドレス" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;">
          <input id="adminPasswordInput" type="password" placeholder="パスワード" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;">
          <button type="submit" class="button" style="width: 100%;">ログイン</button>
        </form>
      </div>
    </div>
  </div>

  <!-- 初回セットアップモーダル -->
  <div class="modal hidden" id="setupModal">
    <div class="modal-panel" style="width: min(520px, 100%); max-height: 90vh; overflow-y: auto;">
      <h2 class="modal-title">はじめてのご利用</h2>
      <p style="color: var(--muted); margin-bottom: 20px;">お名前とクラスを入力してください。</p>
      <form id="setupForm" style="display: grid; gap: 16px;">
        <div style="display: grid; gap: 8px;">
          <label for="setupName" style="font-weight: 700;">お名前</label>
          <input id="setupName" type="text" maxlength="30" placeholder="例：白金 太郎" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;">
        </div>
        <div style="display: grid; gap: 8px;">
          <label for="setupClass" style="font-weight: 700;">クラス</label>
          <select id="setupClass" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;">
            <option value="">選択してください</option>
            <option value="7-1">7-1組</option>
            <option value="7-2">7-2組</option>
          </select>
        </div>

        <div style="margin-top: 12px; padding: 16px; background: rgba(248, 250, 252, 0.9); border-radius: 12px; max-height: 200px; overflow-y: auto; font-size: 0.85rem; line-height: 1.6; color: #555;">
          <strong style="display: block; margin-bottom: 12px;">利用規約とプライバシーポリシーに同意いただく必要があります。</strong>
          <p><strong>利用規約</strong></p>
          <p><strong>第1条（目的）</strong><br>本サイトは、学校内における予定・宿題・連絡事項の共有およびコミュニケーションを目的とします。</p>
          <p><strong>第2条（利用対象）</strong><br>本サイトは、関係する生徒および管理者のみが利用するものとします。</p>
          <p><strong>第3条（禁止事項）</strong><br>利用者は、以下の行為を行ってはなりません。他人を傷つける発言、誹謗中傷、不適切な内容や画像の投稿、なりすまし行為、個人情報（住所・電話番号など）の投稿、サイトの運営を妨害する行為。</p>
          <p><strong>第4条（投稿・コメント）</strong><br>投稿・コメントの内容については、利用者が責任を負います。不適切と判断された場合、管理者により削除されることがあります。</p>
          <p><strong>第5条（管理者権限）</strong><br>管理者は、投稿およびコメントの編集・削除、不適切な利用への対応を行うことができます。</p>
          <p><strong>第6条（データの取り扱い）</strong><br>投稿・コメントなどのデータはシステム上に保存されます。</p>
          <p style="margin-top: 12px;"><strong>プライバシーポリシー</strong></p>
          <p>本サイトでは、名前、クラス、投稿内容・コメント内容を取得する場合があります。取得した情報は、サイトの運営および機能提供、利用状況の把握、不適切な利用への対応に利用します。取得した情報を第三者に提供することはありません。</p>
        </div>

        <label style="display: flex; align-items: center; gap: 8px;">
          <input id="agreeCheckbox" type="checkbox" required>
          <span style="font-size: 0.9rem;">利用規約とプライバシーポリシーに同意します</span>
        </label>

        <button type="submit" class="button" style="width: 100%;">始める</button>
      </form>
    </div>
  </div>

  <!-- メインサイト（ログイン＆承認済みのみ表示） -->
  <div id="mainContent" style="display: none;">
    <button class="mobile-menu-button" id="mobileMenuButton" type="button">≡</button>
    <div class="mobile-menu-overlay" id="mobileMenuOverlay"></div>
    <div class="mobile-menu-panel" id="mobileMenuPanel">
      <button class="mobile-menu-item" data-filter="all">すべて</button>
      <button class="mobile-menu-item" data-filter="予定">予定</button>
      <button class="mobile-menu-item" data-filter="宿題">宿題</button>
      <button class="mobile-menu-item" data-filter="連絡事項">連絡事項</button>
    </div>

    <div class="admin-footer" id="adminFooter" style="display: none;">
      <button class="ghost-button admin-button-small" id="adminDashboardButton" type="button">ダッシュボード</button>
    </div>

    <main class="shell">
      <section class="site-header">
        <article class="hero-card frosted">
          <h1 class="hero-title">予定・宿題・連絡を、毎日見やすく。</h1>
          <p class="hero-lead">1組・2組向けに、授業予定、宿題、連絡事項をひとつにまとめた共有サイトです。</p>
        </article>
      </section>

      <section class="toolbar frosted">
        <div class="toolbar-row">
          <div class="date-nav">
            <button class="ghost-button" id="prevDateButton" type="button">← 前日</button>
            <div class="date-display" id="dateDisplay">読み込み中...</div>
            <button class="ghost-button" id="nextDateButton" type="button">次日 →</button>
          </div>
        </div>
        <div class="toolbar-row">
          <div class="chip-row" id="categoryFilterRow">
            <button class="chip active" data-category-filter="all">すべて</button>
            <button class="chip" data-category-filter="予定">予定</button>
            <button class="chip" data-category-filter="宿題">宿題</button>
            <button class="chip" data-category-filter="連絡事項">連絡事項</button>
          </div>
        </div>
      </section>

      <section id="adminPostForm" style="display: none;">
        <div class="panel frosted">
          <h3 class="panel-title">新しい投稿</h3>
          <form id="postForm" style="display: grid; gap: 16px;">
            <div style="display: grid; gap: 8px;">
              <label for="postTitle" style="font-weight: 700;">タイトル</label>
              <input id="postTitle" type="text" maxlength="100" placeholder="投稿タイトル" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;">
            </div>
            <div style="display: grid; gap: 8px;">
              <label for="postBody" style="font-weight: 700;">内容</label>
              <textarea id="postBody" placeholder="投稿内容" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px; min-height: 120px;"></textarea>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
              <div style="display: grid; gap: 8px;">
                <label for="postCategory" style="font-weight: 700;">カテゴリ</label>
                <select id="postCategory" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;">
                  <option value="">選択</option>
                  <option value="予定">予定</option>
                  <option value="宿題">宿題</option>
                  <option value="連絡事項">連絡事項</option>
                </select>
              </div>
              <div style="display: grid; gap: 8px;">
                <label for="postTarget" style="font-weight: 700;">対象クラス</label>
                <select id="postTarget" required style="padding: 12px 14px; border: 1px solid var(--border); border-radius: 12px;">
                  <option value="">選択</option>
                  <option value="7-1">7-1組</option>
                  <option value="7-2">7-2組</option>
                  <option value="両方">全体向け</option>
                </select>
              </div>
            </div>
            <div style="display: flex; gap: 10px;">
              <button type="submit" class="button">投稿</button>
            </div>
          </form>
        </div>
      </section>

      <section id="postsContainer"></section>
    </main>
  </div>

  <div class="toast" id="toast"></div>

  <!-- 管理者ダッシュボード -->
  <div class="modal hidden" id="adminDashboardModal">
    <div class="modal-panel" style="width: min(800px, 100%); max-height: 90vh; overflow: auto;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h2 class="modal-title">管理者ダッシュボード</h2>
        <button type="button" onclick="closeAdminDashboard()" class="ghost-button" style="min-height: 40px;">閉じる</button>
      </div>

      <div style="display: grid; gap: 24px;">
        <!-- 申請者一覧 -->
        <div>
          <h3 style="font-size: 1.2rem; margin-bottom: 16px;">🔔 申請中のユーザー</h3>
          <div id="pendingUsersList" style="display: grid; gap: 12px;"></div>
        </div>

        <!-- 承認済みユーザー一覧 -->
        <div>
          <h3 style="font-size: 1.2rem; margin-bottom: 16px;">✅ 承認済みユーザー</h3>
          <div id="allowedUsersList" style="display: grid; gap: 12px;"></div>
        </div>
      </div>
    </div>
  </div>

  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-app.js";
    import {
      getAuth,
      signInWithEmailAndPassword,
      createUserWithEmailAndPassword,
      signInWithPopup,
      GoogleAuthProvider,
      signOut,
      onAuthStateChanged
    } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-auth.js";
    import {
      getFirestore,
      collection,
      onSnapshot,
      addDoc,
      deleteDoc,
      doc,
      getDoc,
      setDoc
    } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-firestore.js";

    const firebaseConfig = {
      apiKey: "AIzaSyAkMLCyIC0x9bT63LEih1x7BXe3XYVuknQ",
      authDomain: "school-site-475fc.firebaseapp.com",
      projectId: "school-site-475fc",
      storageBucket: "school-site-475fc.firebasestorage.app",
      messagingSenderId: "69139986081",
      appId: "1:69139986081:web:11c1b1b8277e503e9ee2e0"
    };

    const firebaseApp = initializeApp(firebaseConfig);
    const auth = getAuth(firebaseApp);
    const db = getFirestore(firebaseApp);
    const googleProvider = new GoogleAuthProvider();

    const state = {
      user: null,
      isAdmin: false,
      isAllowed: false,
      userName: "",
      userClass: "",
      categoryFilter: "all",
      currentDate: new Date(),
      posts: [],
      comments: {}
    };

    function showToast(message) {
      const toast = document.getElementById("toast");
      toast.textContent = message;
      toast.classList.add("show");
      setTimeout(() => toast.classList.remove("show"), 2400);
    }

    function updateDateDisplay() {
      const options = { year: "numeric", month: "long", day: "numeric", weekday: "short" };
      document.getElementById("dateDisplay").textContent = state.currentDate.toLocaleDateString("ja-JP", options);
    }

    function filterPosts() {
      const dateStr = state.currentDate.toISOString().split('T')[0];
      return state.posts.filter(post => {
        const matchesCategory = state.categoryFilter === "all" || post.category === state.categoryFilter;
        const matchesDate = post.date === dateStr;
        const matchesClass = post.classTarget === "両方" || post.classTarget === state.userClass;
        return matchesCategory && matchesDate && matchesClass;
      });
    }

    function renderPosts() {
      const container = document.getElementById("postsContainer");
      const filtered = filterPosts();

      if (filtered.length === 0) {
        container.innerHTML = `<div class="empty-state">この日の投稿がありません。</div>`;
        return;
      }

      container.innerHTML = filtered.map(post => `
        <div class="post-card">
          <div class="post-header">
            <h3 class="post-title">${post.title}</h3>
            ${state.isAdmin ? `
              <button onclick="deletePost('${post.id}')" class="danger-button" style="min-height: 36px; padding: 0 12px; font-size: 0.85rem;">削除</button>
            ` : ""}
          </div>
          <div style="margin-bottom: 12px;">
            <span class="badge ${getCategoryClass(post.category)}">${post.category}</span>
            <span class="badge" style="background: rgba(15, 23, 42, 0.06); color: #334155;">${post.classTarget === "両方" ? "全体向け" : post.classTarget + "向け"}</span>
          </div>
          <p class="post-body">${post.body}</p>
          
          <div style="margin-top: 16px; border-top: 1px solid rgba(148, 163, 184, 0.16); padding-top: 16px;">
            <strong style="display: block; margin-bottom: 12px; font-size: 0.95rem;">コメント</strong>
            <div id="comments-${post.id}" style="display: grid; gap: 12px; margin-bottom: 12px;"></div>
            
            <form onsubmit="addComment(event, '${post.id}')" style="display: grid; gap: 10px;">
              <textarea name="commentText" placeholder="コメントを入力..." required style="padding: 10px 12px; border: 1px solid var(--border); border-radius: 12px; min-height: 80px; font-family: inherit;"></textarea>
              <button type="submit" class="button" style="align-self: flex-start;">送信</button>
            </form>
          </div>
        </div>
      `).join("");

      state.posts.forEach(post => {
        const commentsContainer = document.getElementById(`comments-${post.id}`);
        if (commentsContainer) {
          const postComments = state.comments[post.id] || [];
          commentsContainer.innerHTML = postComments.length > 0
            ? postComments.map(comment => `
              <div class="comment-item">
                <div class="comment-author">${comment.author}</div>
                <div class="comment-text">${comment.text}</div>
                ${state.isAdmin ? `
                  <button onclick="deleteComment('${post.id}', '${comment.id}')" class="danger-button" style="margin-top: 8px; min-height: 36px; padding: 0 12px; font-size: 0.85rem;">削除</button>
                ` : ""}
              </div>
            `).join("")
            : `<p style="color: var(--muted); font-size: 0.9rem;">コメントはまだありません</p>`;
        }
      });
    }

    function getCategoryClass(category) {
      const classes = {
        "予定": "schedule",
        "宿題": "homework",
        "連絡事項": "notice"
      };
      return classes[category] || "schedule";
    }

    window.deletePost = async function(postId) {
      if (!confirm("投稿を削除しますか？")) return;
      try {
        await deleteDoc(doc(db, "posts", postId));
        showToast("投稿を削除しました");
      } catch (error) {
        showToast("削除に失敗しました");
      }
    };

    window.addComment = async function(event, postId) {
      event.preventDefault();
      const textarea = event.target.querySelector("textarea");
      const text = textarea.value.trim();
      if (!text) return;

      try {
        const commentsRef = collection(db, "posts", postId, "comments");
        await addDoc(commentsRef, {
          author: state.userName,
          text: text,
          createdAt: new Date().toISOString()
        });
        textarea.value = "";
        showToast("コメントを追加しました");
      } catch (error) {
        showToast("コメント追加に失敗しました");
      }
    };

    window.deleteComment = async function(postId, commentId) {
      if (!confirm("削除しますか？")) return;
      try {
        await deleteDoc(doc(db, "posts", postId, "comments", commentId));
        showToast("コメントを削除しました");
      } catch (error) {
        showToast("削除に失敗しました");
      }
    };

    // === ユーザーオンライン状態の管理 ===
    async function setUserOnline(isOnline) {
      if (!state.user) return;
      try {
        const userRef = doc(db, "allowedUsers", state.user.uid);
        await setDoc(userRef, {
          lastActive: new Date().toISOString(),
          isOnline: isOnline
        }, { merge: true });
      } catch (error) {
        console.error("オンライン状態の更新に失敗:", error);
      }
    }

    // ログイン時
    onAuthStateChanged(auth, async (user) => {
      if (user) {
        await setUserOnline(true);
      }
    });

    // ページ離脱時
    window.addEventListener("beforeunload", async () => {
      if (state.user) {
        await setUserOnline(false);
      }
    });

    // ページが非アクティブになったら
    document.addEventListener("visibilitychange", async () => {
      if (document.hidden) {
        if (state.user) {
          await setUserOnline(false);
        }
      } else {
        if (state.user) {
          await setUserOnline(true);
        }
      }
    });
      if (!user) {
        // ログインしていない
        document.getElementById("loginModal").classList.remove("hidden");
        document.getElementById("mainContent").style.display = "none";
        return;
      }

      state.user = user;

      // Firestore で許可を確認
      const allowedRef = doc(db, "allowedUsers", user.uid);
      const allowedSnap = await getDoc(allowedRef);

      if (allowedSnap.exists()) {
        // 許可済み
        state.isAllowed = true;
        state.isAdmin = allowedSnap.data().isAdmin || false;
        
        // localStorage から名前とクラスを確認
        const savedSetup = localStorage.getItem(`user_setup_${user.uid}`);
        
        if (!savedSetup) {
          // 初回利用 → セットアップモーダル表示
          document.getElementById("loginModal").classList.add("hidden");
          document.getElementById("mainContent").style.display = "none";
          document.getElementById("setupModal").classList.remove("hidden");
          return;
        }
        
        // セットアップ済み
        const setup = JSON.parse(savedSetup);
        state.userName = setup.name;
        state.userClass = setup.class;
        
        document.getElementById("loginModal").classList.add("hidden");
        document.getElementById("mainContent").style.display = "block";
        document.getElementById("setupModal").classList.add("hidden");
        
        document.getElementById("adminPostForm").style.display = state.isAdmin ? "block" : "none";
        document.getElementById("adminFooter").style.display = state.isAdmin ? "block" : "none";

        // 投稿とコメントを読み込み
        const postsRef = collection(db, "posts");
        onSnapshot(postsRef, (snapshot) => {
          state.posts = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
          
          state.posts.forEach(post => {
            const commentsRef = collection(db, "posts", post.id, "comments");
            onSnapshot(commentsRef, (commentSnapshot) => {
              state.comments[post.id] = commentSnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
              renderPosts();
            });
          });
          renderPosts();
        });
      } else {
        // 未承認 → pendingUsers へ申請書を作成
        const pendingRef = doc(db, "pendingUsers", user.uid);
        const pendingSnap = await getDoc(pendingRef);

        if (!pendingSnap.exists()) {
          // 初回申請
          await setDoc(pendingRef, {
            email: user.email,
            name: user.displayName || "未設定",
            appliedAt: new Date().toISOString()
          });
        }

        document.getElementById("loginModal").classList.add("hidden");
        document.getElementById("mainContent").style.display = "none";
        document.getElementById("setupModal").classList.add("hidden");
      }
    });

    // === Google ログイン ===
    document.getElementById("googleLoginButton").addEventListener("click", async () => {
      try {
        const result = await signInWithPopup(auth, googleProvider);
        // Google ログインは自動的に onAuthStateChanged で処理される
        showToast("ログインしました");
      } catch (error) {
        showToast("ログインに失敗しました");
      }
    });

    // === メール登録（自動アカウント作成に変更） ===

    document.getElementById("emailLoginForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = document.getElementById("emailInput").value;
      const password = document.getElementById("passwordInput").value;

      try {
        // まずログインを試す
        try {
          await signInWithEmailAndPassword(auth, email, password);
          showToast("ログインしました");
        } catch (loginError) {
          // ログイン失敗 → 新規作成として扱う
          if (loginError.code === "auth/user-not-found" || loginError.code === "auth/invalid-credential") {
            await createUserWithEmailAndPassword(auth, email, password);
            showToast("アカウントを作成しました");
          } else {
            throw loginError;
          }
        }
      } catch (error) {
        showToast("ログインに失敗しました");
      }
    });

    // === ログアウト ===

    // === セットアップフォーム ===
    document.getElementById("setupForm").addEventListener("submit", (e) => {
      e.preventDefault();
      const name = document.getElementById("setupName").value;
      const userClass = document.getElementById("setupClass").value;

      if (!name || !userClass) {
        showToast("名前とクラスを入力してください");
        return;
      }

      state.userName = name;
      state.userClass = userClass;
      localStorage.setItem(`user_setup_${state.user.uid}`, JSON.stringify({ name, class: userClass }));

      document.getElementById("setupModal").classList.add("hidden");
      document.getElementById("mainContent").style.display = "block";

      // 投稿とコメントを読み込み
      const postsRef = collection(db, "posts");
      onSnapshot(postsRef, (snapshot) => {
        state.posts = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
        
        state.posts.forEach(post => {
          const commentsRef = collection(db, "posts", post.id, "comments");
          onSnapshot(commentsRef, (commentSnapshot) => {
            state.comments[post.id] = commentSnapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
            renderPosts();
          });
        });
        renderPosts();
      });

      showToast(`${name} で始めます（${userClass}組）`);
    });

    // === タブ切り替え ===
    document.getElementById("userTabButton").addEventListener("click", () => {
      document.getElementById("userLoginTab").style.display = "block";
      document.getElementById("adminLoginTab").style.display = "none";
      document.getElementById("userTabButton").classList.remove("ghost-button");
      document.getElementById("userTabButton").classList.add("button");
      document.getElementById("adminTabButton").classList.remove("button");
      document.getElementById("adminTabButton").classList.add("ghost-button");
    });

    document.getElementById("adminTabButton").addEventListener("click", () => {
      document.getElementById("userLoginTab").style.display = "none";
      document.getElementById("adminLoginTab").style.display = "block";
      document.getElementById("userTabButton").classList.remove("button");
      document.getElementById("userTabButton").classList.add("ghost-button");
      document.getElementById("adminTabButton").classList.remove("ghost-button");
      document.getElementById("adminTabButton").classList.add("button");
    });

    // === 管理者ログイン ===
    document.getElementById("adminLoginForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = document.getElementById("adminEmailInput").value;
      const password = document.getElementById("adminPasswordInput").value;

      try {
        await signInWithEmailAndPassword(auth, email, password);
        showToast("ログインしました");
      } catch (error) {
        showToast("ログインに失敗しました");
      }
    });

    // === 投稿フォーム ===
    document.getElementById("postForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const title = document.getElementById("postTitle").value;
      const body = document.getElementById("postBody").value;
      const category = document.getElementById("postCategory").value;
      const target = document.getElementById("postTarget").value;

      try {
        await addDoc(collection(db, "posts"), {
          title,
          body,
          category,
          classTarget: target,
          date: new Date().toISOString().split('T')[0],
          createdAt: new Date().toISOString()
        });
        document.getElementById("postForm").reset();
        showToast("投稿しました");
      } catch (error) {
        showToast("投稿に失敗しました");
      }
    });

    // === 日付ナビゲーション ===
    document.getElementById("prevDateButton").addEventListener("click", () => {
      state.currentDate.setDate(state.currentDate.getDate() - 1);
      updateDateDisplay();
      renderPosts();
    });

    document.getElementById("nextDateButton").addEventListener("click", () => {
      state.currentDate.setDate(state.currentDate.getDate() + 1);
      updateDateDisplay();
      renderPosts();
    });

    // === カテゴリフィルター ===
    document.querySelectorAll("[data-category-filter]").forEach(btn => {
      btn.addEventListener("click", () => {
        state.categoryFilter = btn.dataset.categoryFilter;
        document.querySelectorAll("[data-category-filter]").forEach(b => {
          b.classList.toggle("active", b.dataset.categoryFilter === state.categoryFilter);
        });
        renderPosts();
      });
    });

    document.querySelectorAll(".mobile-menu-item").forEach(item => {
      item.addEventListener("click", () => {
        state.categoryFilter = item.dataset.filter;
        document.querySelectorAll("[data-category-filter]").forEach(btn => {
          btn.classList.toggle("active", btn.dataset.categoryFilter === state.categoryFilter);
        });
        renderPosts();
        document.getElementById("mobileMenuPanel").classList.remove("active");
        document.getElementById("mobileMenuOverlay").classList.remove("active");
      });
    });

    document.getElementById("mobileMenuButton").addEventListener("click", () => {
      document.getElementById("mobileMenuPanel").classList.toggle("active");
      document.getElementById("mobileMenuOverlay").classList.toggle("active");
    });

    document.getElementById("mobileMenuOverlay").addEventListener("click", () => {
      document.getElementById("mobileMenuPanel").classList.remove("active");
      document.getElementById("mobileMenuOverlay").classList.remove("active");
    });

    // === グローバル関数（管理者ダッシュボード用） ===
    window.approveUser = async function(uid, email) {
      if (!confirm(`${email} を承認しますか？`)) return;
      try {
        await setDoc(doc(db, "allowedUsers", uid), {
          email: email,
          isAdmin: false,
          approvedAt: new Date().toISOString()
        });
        await deleteDoc(doc(db, "pendingUsers", uid));
        showToast("ユーザーを承認しました");
        loadAdminData();
      } catch (error) {
        showToast("承認に失敗しました");
      }
    };

    window.rejectUser = async function(uid) {
      if (!confirm("申請を拒否しますか？")) return;
      try {
        await deleteDoc(doc(db, "pendingUsers", uid));
        showToast("申請を拒否しました");
        loadAdminData();
      } catch (error) {
        showToast("拒否に失敗しました");
      }
    };

    window.removeUser = async function(uid, email) {
      if (!confirm(`${email} のアクセスを取り消しますか？`)) return;
      try {
        await deleteDoc(doc(db, "allowedUsers", uid));
        showToast("ユーザーを削除しました");
        loadAdminData();
      } catch (error) {
        showToast("削除に失敗しました");
      }
    };

    window.closeAdminDashboard = function() {
      document.getElementById("adminDashboardModal").classList.add("hidden");
    };

    async function loadAdminData() {
      const pendingList = document.getElementById("pendingUsersList");
      const allowedList = document.getElementById("allowedUsersList");

      // 申請者を読み込み
      const pendingRef = collection(db, "pendingUsers");
      onSnapshot(pendingRef, (snapshot) => {
        const pending = snapshot.docs.map(doc => ({ uid: doc.id, ...doc.data() }));
        
        if (pending.length === 0) {
          pendingList.innerHTML = `<p style="color: var(--muted); text-align: center; padding: 20px;">申請者はいません</p>`;
        } else {
          pendingList.innerHTML = pending.map(user => `
            <div style="background: rgba(248, 250, 252, 0.9); border: 1px solid var(--border); border-radius: 16px; padding: 16px; display: flex; justify-content: space-between; align-items: center; gap: 12px;">
              <div>
                <strong style="display: block; margin-bottom: 4px;">${user.name || "未設定"}</strong>
                <small style="color: var(--muted); display: block; margin-bottom: 4px;">${user.email}</small>
                <small style="color: var(--muted);">申請日: ${new Date(user.appliedAt).toLocaleDateString("ja-JP")}</small>
              </div>
              <div style="display: flex; gap: 8px;">
                <button onclick="approveUser('${user.uid}', '${user.email}')" class="button" style="min-height: 36px; padding: 0 12px; font-size: 0.85rem;">承認</button>
                <button onclick="rejectUser('${user.uid}')" class="danger-button" style="min-height: 36px; padding: 0 12px; font-size: 0.85rem;">拒否</button>
              </div>
            </div>
          `).join("");
        }
      });

      // 承認済みユーザーを読み込み
      const allowedRef = collection(db, "allowedUsers");
      onSnapshot(allowedRef, (snapshot) => {
        const allowed = snapshot.docs.map(doc => ({ uid: doc.id, ...doc.data() }));
        
        if (allowed.length === 0) {
          allowedList.innerHTML = `<p style="color: var(--muted); text-align: center; padding: 20px;">承認済みユーザーはいません</p>`;
        } else {
          allowedList.innerHTML = allowed.map(user => {
            const isOnline = user.isOnline;
            const onlineStatus = isOnline ? "🟢 オンライン" : "⚪ オフライン";
            return `
            <div style="background: rgba(248, 250, 252, 0.9); border: 1px solid var(--border); border-radius: 16px; padding: 16px; display: flex; justify-content: space-between; align-items: center; gap: 12px;">
              <div>
                <strong style="display: block; margin-bottom: 4px;">${user.email}</strong>
                <small style="color: var(--muted); display: block; margin-bottom: 4px;">${onlineStatus}</small>
                <small style="color: var(--muted);">承認日: ${new Date(user.approvedAt).toLocaleDateString("ja-JP")} ${user.isAdmin ? "👑 管理者" : ""}</small>
              </div>
              <button onclick="removeUser('${user.uid}', '${user.email}')" class="danger-button" style="min-height: 36px; padding: 0 12px; font-size: 0.85rem;">削除</button>
            </div>
            `;
          }).join("");
        }
      });
    }

    // === ダッシュボードボタン ===
    document.getElementById("adminDashboardButton").addEventListener("click", () => {
      if (!state.isAdmin) {
        showToast("管理者のみアクセス可能です");
        return;
      }
      document.getElementById("adminDashboardModal").classList.remove("hidden");
      loadAdminData();
    });

    updateDateDisplay();
  </script>
</body>
</html>
